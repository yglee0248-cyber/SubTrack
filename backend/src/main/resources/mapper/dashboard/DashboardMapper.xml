<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.subtrack.domain.dashboard.dao.DashboardDao">

    <resultMap id="UpcomingSubscriptionResultMap" type="com.subtrack.domain.dashboard.vo.UpcomingSubscription">
        <id property="subscriptionId" column="subscription_id" />
        <result property="name" column="name" />
        <result property="categoryId" column="category_id" />
        <result property="categoryName" column="category_name" />
        <result property="price" column="price" />
        <result property="currency" column="currency" />
        <result property="nextPaymentDate" column="next_payment_date" />
    </resultMap>

    <resultMap id="DashboardSubscriptionResultMap" type="com.subtrack.domain.dashboard.vo.DashboardSubscription">
        <id property="subscriptionId" column="subscription_id" />
        <result property="name" column="name" />
        <result property="categoryId" column="category_id" />
        <result property="categoryName" column="category_name" />
        <result property="colorCode" column="color_code" />
        <result property="icon" column="icon" />
        <result property="price" column="price" />
        <result property="currency" column="currency" />
        <result property="billingCycle" column="billing_cycle" />
        <result property="billingAnchorDay" column="billing_anchor_day" />
        <result property="billingStartDate" column="billing_start_date" />
        <result property="paymentMethod" column="payment_method" />
        <result property="deletedAt" column="deleted_at" />
    </resultMap>

    <sql id="CurrentActiveSubscriptionCondition">
        s.member_id = #{memberId}
        AND s.status = 'ACTIVE'
        AND s.deleted_at IS NULL
    </sql>

    <select id="countUpcomingSubscriptions" resultType="int">
        SELECT COUNT(*)
        FROM subscription s
        WHERE <include refid="CurrentActiveSubscriptionCondition" />
          AND s.next_payment_date BETWEEN #{today} AND #{endDate}
    </select>

    <select id="countDueTodaySubscriptions" resultType="int">
        SELECT COUNT(*)
        FROM subscription s
        WHERE <include refid="CurrentActiveSubscriptionCondition" />
          AND s.next_payment_date = #{today}
    </select>

    <select id="findRecurringDashboardSubscriptions" resultMap="DashboardSubscriptionResultMap">
        SELECT
            s.subscription_id,
            s.name,
            s.category_id,
            c.name AS category_name,
            c.color_code,
            c.icon,
            s.price,
            s.currency,
            s.billing_cycle,
            s.billing_anchor_day,
            s.billing_start_date,
            s.payment_method,
            s.deleted_at
        FROM subscription s
        INNER JOIN subscription_category c ON s.category_id = c.category_id
        WHERE s.member_id = #{memberId}
          AND s.deleted_at IS NULL
          AND s.billing_start_date &lt;= #{endDate}
    </select>

    <select id="findUpcomingSubscriptions" resultMap="UpcomingSubscriptionResultMap">
        SELECT
            s.subscription_id,
            s.name,
            s.category_id,
            c.name AS category_name,
            s.price,
            s.currency,
            s.next_payment_date
        FROM subscription s
        INNER JOIN subscription_category c ON s.category_id = c.category_id
        WHERE <include refid="CurrentActiveSubscriptionCondition" />
          AND s.next_payment_date BETWEEN #{today} AND #{endDate}
        ORDER BY s.next_payment_date ASC, s.subscription_id DESC
    </select>

</mapper>
